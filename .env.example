# ---------------------------------------------------------------------------
# Environment variables for the personal dashboard.
#
# Copy this file to `.env.local` and fill in the values from your own Supabase
# project. `.env.local` is git-ignored and must never be committed.
#
#   cp .env.example .env.local          # macOS / Linux
#   Copy-Item .env.example .env.local   # Windows PowerShell
#
# Where to find these values: Supabase Dashboard -> your project ->
# Project Settings -> API.
# ---------------------------------------------------------------------------

# Public Supabase project URL. Safe to expose to the browser.
# Project Settings -> API -> Project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public (publishable / anon) API key. Safe to expose to the browser; it only
# grants the limited access allowed by your Row Level Security policies.
# Project Settings -> API -> Project API keys -> publishable / anon key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# SERVER-ONLY secret (service-role) key. Full database access — NEVER expose
# this to the browser and never prefix it with NEXT_PUBLIC_. Used only by
# server code that has already verified the administrator.
# Project Settings -> API -> Project API keys -> secret / service_role key
SUPABASE_SECRET_KEY=

# The Supabase Auth user id (UUID) of the single administrator account.
# After creating your admin user (see README "Create the administrator"),
# copy its id from Authentication -> Users.
ADMIN_USER_ID=
